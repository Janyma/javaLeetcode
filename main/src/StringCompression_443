class StringCompression_443 {
    public int compress(char[] chars) {
        int len= chars.length;
        int streakStart=0;
        int streakAnswer=0;
        while(streakStart<len){
            char streakChar= chars[streakStart];
            int streakEnd=streakStart;
            int count=1;


            while(streakEnd+1<len && streakChar==chars[streakEnd+1]){
                streakEnd++;
                count++;

            }
            chars[streakAnswer]=streakChar;
            streakAnswer++;
            if(count!=1){
                char[] a= Integer.toString(count).toCharArray();
                for(char b: a){
                    chars[streakAnswer]=b;
                    streakAnswer++;
                }

            }
            streakStart=streakEnd+1;
        }
        
        return streakAnswer;
        
    }
}